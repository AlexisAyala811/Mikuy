@{
    ViewData["Title"] = "Contacto";
}

<section class="container contact-layout">
    <div>
        <p class="eyebrow">Visitenos</p>
        <h1>Contacto Mikuy</h1>
        <p><strong>Direccion:</strong> Huamanga, Ayacucho, Peru</p>
        <p><strong>Telefono:</strong> +51 999 999 999</p>
        <p><strong>Correo:</strong> reservas@mikuy.pe</p>
        <p><strong>Horario:</strong> Lunes a domingo de 12:00 p. m. a 10:00 p. m.</p>
        <a asp-controller="Reservas" asp-action="Reservar" class="btn btn-accent">Reservar una mesa</a>
    </div>
    <div class="map-panel" aria-label="Ubicacion referencial de Mikuy">
        <span>Huamanga</span>
        <strong>Ayacucho</strong>
        <p>Centro historico y cocina regional</p>
    </div>
</section>

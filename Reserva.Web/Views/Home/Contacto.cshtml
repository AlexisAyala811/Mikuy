@{
    ViewData["Title"] = "Contacto";
}

<section class="container contact-layout">
    <div>
        <p class="eyebrow">Visitenos</p>
        <h1>Contacto Mikuy</h1>
        <p><strong>Direccion:</strong> Huamanga, Ayacucho, Peru</p>
        <p><strong>Telefono:</strong> +51 999 999 999</p>
        <p><strong>Correo:</strong> reservas@mikuy.pe</p>
        <p><strong>Horario:</strong> Lunes a domingo de 12:00 p. m. a 10:00 p. m.</p>
        <div class="contact-actions">
            <a asp-controller="Reservas" asp-action="Reservar" class="btn btn-accent">Reservar una mesa</a>
            <a href="tel:+51999999999" class="btn btn-outline-dark">Llamar</a>
        </div>
    </div>
    <div class="map-embed-panel">
        <iframe
            title="Mapa de Mikuy en Huamanga, Ayacucho"
            src="https://www.google.com/maps?q=Huamanga%2C%20Ayacucho%2C%20Peru&output=embed"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen>
        </iframe>
        <div class="map-caption">
            <span>Huamanga</span>
            <strong>Ayacucho, Peru</strong>
            <a href="https://www.google.com/maps/search/?api=1&query=Huamanga%2C%20Ayacucho%2C%20Peru" target="_blank" rel="noopener">Abrir en Google Maps</a>
        </div>
    </div>
</section>

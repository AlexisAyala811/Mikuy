@{
    ViewData["Title"] = "Cultura";
}

<section class="page-hero culture-page">
    <div class="container">
        <p class="eyebrow">Ayacucho vivo</p>
        <h1>Cultura que llega a la mesa</h1>
        <p>Retablos, Semana Santa, carnaval, artesania y cocina tradicional dan forma a la identidad de Mikuy.</p>
    </div>
</section>

<section class="container culture-stories">
    <article>
        <img src="~/img/cultura/retablo.png" alt="Retablo ayacuchano" loading="lazy" />
        <h2>Arte huamanguino</h2>
        <p>Los retablos y la artesania convierten color, memoria y oficio en piezas que narran la vida local.</p>
    </article>
    <article>
        <img src="~/img/cultura/fiesta.png" alt="Celebracion tradicional en Ayacucho" loading="lazy" />
        <h2>Fiesta y encuentro</h2>
        <p>La mesa comparte el pulso de las celebraciones ayacuchanas: aromas intensos y tiempo para reunirse.</p>
    </article>
</section>

<section class="container section-space">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Galeria Mikuy</p>
            <h2>Ambiente, tradicion y mesa compartida</h2>
        </div>
    </div>
    <div class="gallery-grid">
        <figure>
            <img src="~/img/hero/mikuy-ayacucho.png" alt="Ambiente de Mikuy inspirado en Ayacucho" loading="lazy" />
            <figcaption>Salon con identidad ayacuchana</figcaption>
        </figure>
        <figure>
            <img src="~/img/cultura/huamanga.png" alt="Vista de Huamanga" loading="lazy" />
            <figcaption>Huamanga como punto de encuentro</figcaption>
        </figure>
        <figure>
            <img src="~/img/platos/cuy-chactado.png" alt="Cuy chactado servido en Mikuy" loading="lazy" />
            <figcaption>Sabores para celebrar</figcaption>
        </figure>
        <figure>
            <img src="~/img/platos/mondongo.png" alt="Mondongo ayacuchano" loading="lazy" />
            <figcaption>Cocina tradicional de temporada</figcaption>
        </figure>
    </div>
</section>

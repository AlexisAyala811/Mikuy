<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content confirm-modal">
            <div class="modal-header">
                <div>
                    <p class="eyebrow mb-1">Accion irreversible</p>
                    <h2 class="modal-title h5" id="confirmDeleteTitle">Confirmar eliminacion</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">Esta accion no se puede deshacer.</p>
                <p class="fw-semibold mb-0" data-delete-message></p>
                <p class="delete-modal-hint mb-0">Puedes volver con Cancelar, la tecla Esc o haciendo clic fuera de esta ventana.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form method="post" data-delete-form>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" data-delete-id />
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

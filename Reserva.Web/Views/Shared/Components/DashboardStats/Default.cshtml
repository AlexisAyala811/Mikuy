@model DashboardStatsViewModel

<div class="dashboard-grid">
    <article class="metric-card">
        <span class="metric-label">Reservas de hoy</span>
        <strong>@Model.ReservasHoy</strong>
        <small>Agenda del dia</small>
    </article>
    <article class="metric-card">
        <span class="metric-label">Pendientes</span>
        <strong>@Model.ReservasPendientes</strong>
        <small>Requieren decision</small>
    </article>
    <article class="metric-card">
        <span class="metric-label">Confirmadas</span>
        <strong>@Model.ReservasConfirmadas</strong>
        <small>Servicio asegurado</small>
    </article>
    <article class="metric-card">
        <span class="metric-label">Canceladas</span>
        <strong>@Model.ReservasCanceladas</strong>
        <small>Fuera de la agenda</small>
    </article>
    <article class="metric-card occupancy-card occupancy-@Model.OcupacionEstado">
        <span class="metric-label">Ocupacion</span>
        <strong>@Model.OcupacionPorcentaje%</strong>
        <small>@Model.MesasOcupadasActuales/@Model.MesasActivas mesas</small>
        <em>@Model.OcupacionMensaje</em>
    </article>
    <article class="metric-card">
        <span class="metric-label">Clientes esperados</span>
        <strong>@Model.ClientesEsperados</strong>
        <small>Personas por atender</small>
    </article>
</div>

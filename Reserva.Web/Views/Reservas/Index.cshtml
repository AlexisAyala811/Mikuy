@model IPagedList<ReservaDto>
@using Reserva.Domain.Entities

@{ 
    ViewData["Title"] = "Reservas";
    var today = DateOnly.FromDateTime(DateTime.Today);
    var filterModel = new TableFilterViewModel
    {
        Search = ViewBag.Search,
        Sort = ViewBag.Sort,
        Estado = ViewBag.Estado,
        Fecha = ViewBag.Fecha,
        ShowEstado = true,
        ShowFecha = true,
        SearchPlaceholder = "Buscar por cliente o estado",
        EstadoOptions = new[]
        {
            new SelectListItem("Pendiente", "Pendiente", ViewBag.Estado == "Pendiente"),
            new SelectListItem("Confirmada", "Confirmada", ViewBag.Estado == "Confirmada"),
            new SelectListItem("Cancelada", "Cancelada", ViewBag.Estado == "Cancelada")
        },
        SortOptions = new[]
        {
            new SelectListItem("Fecha reciente", "", ViewBag.Sort is null or ""),
            new SelectListItem("Fecha antigua", "fecha", ViewBag.Sort == "fecha"),
            new SelectListItem("Hora", "hora", ViewBag.Sort == "hora"),
            new SelectListItem("Cliente", "cliente", ViewBag.Sort == "cliente"),
            new SelectListItem("Estado", "estado", ViewBag.Sort == "estado")
        }
    };
}

<section class="container page-shell admin-page reservations-index">
    <div class="page-heading">
        <div>
            <h1>Reservas</h1>
            <p>Primero se muestran las solicitudes pendientes y los proximos servicios.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">Nueva reserva</a>
    </div>

    <partial name="_TableFilters" model="filterModel" />

    <div class="table-responsive mt-3">
        <table class="table table-hover align-middle app-table">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Codigo</th>
                    <th>Hora</th>
                    <th>Cliente</th>
                    <th>Mesa</th>
                    <th>Personas</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    var isPriority = item.Estado == EstadosReserva.Pendiente && item.Fecha >= today;
                    var isPast = item.Fecha < today;
                    <tr class="@(isPriority ? "reservation-row-priority" : "") @(isPast ? "reservation-row-history" : "")">
                        <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                        <td><span class="reservation-code">@item.CodigoReserva</span></td>
                        <td>@item.Hora.ToString("HH:mm")</td>
                        <td class="fw-semibold">@item.ClienteNombre</td>
                        <td>@item.MesaDescripcion</td>
                        <td>@item.CantidadPersonas</td>
                        <td><span class="status-badge status-@item.Estado.ToLowerInvariant()">@item.Estado</span></td>
                        <td class="text-end">
                            <div class="reservation-actions">
                                <a asp-action="Details" asp-route-id="@item.IdReserva" class="row-primary-action">Ver detalle</a>
                                <div class="dropdown">
                                    <button class="row-more-actions" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Mas acciones para la reserva @item.CodigoReserva">•••</button>
                                    <ul class="dropdown-menu dropdown-menu-end reservation-action-menu">
                                        <li><a asp-action="Edit" asp-route-id="@item.IdReserva" class="dropdown-item">Editar reserva</a></li>
                                        <li><a asp-action="Comprobante" asp-route-id="@item.IdReserva" class="dropdown-item">Descargar PDF</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a asp-action="Delete" asp-route-id="@item.IdReserva" class="dropdown-item text-danger">Eliminar reserva</a></li>
                                    </ul>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">No se encontraron reservas.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination"
             model="Model"
             view-data='new ViewDataDictionary(ViewData) { ["AriaLabel"] = "Paginacion de reservas", ["RouteValues"] = new { search = ViewBag.Search, estado = ViewBag.Estado, fecha = ViewBag.Fecha, sort = ViewBag.Sort } }' />
</section>

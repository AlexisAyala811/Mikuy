@model IPagedList<ReservaDto>

@{
    ViewData["Title"] = "Reservas";
    var filterModel = new TableFilterViewModel
    {
        Search = ViewBag.Search,
        Sort = ViewBag.Sort,
        Estado = ViewBag.Estado,
        Fecha = ViewBag.Fecha,
        ShowEstado = true,
        ShowFecha = true,
        SearchPlaceholder = "Buscar por cliente o estado",
        EstadoOptions = new[]
        {
            new SelectListItem("Pendiente", "Pendiente", ViewBag.Estado == "Pendiente"),
            new SelectListItem("Confirmada", "Confirmada", ViewBag.Estado == "Confirmada"),
            new SelectListItem("Cancelada", "Cancelada", ViewBag.Estado == "Cancelada")
        },
        SortOptions = new[]
        {
            new SelectListItem("Fecha reciente", "", ViewBag.Sort is null or ""),
            new SelectListItem("Fecha antigua", "fecha", ViewBag.Sort == "fecha"),
            new SelectListItem("Hora", "hora", ViewBag.Sort == "hora"),
            new SelectListItem("Cliente", "cliente", ViewBag.Sort == "cliente"),
            new SelectListItem("Estado", "estado", ViewBag.Sort == "estado")
        }
    };
}

<section class="page-shell">
    <div class="page-heading">
        <div>
            <h1>Reservas</h1>
            <p>Consulta, agenda, filtra y evita cruces de horarios.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">Nueva reserva</a>
    </div>

    <partial name="_TableFilters" model="filterModel" />

    @if (TempData["WhatsAppUrl"] is string whatsAppUrl && !string.IsNullOrWhiteSpace(whatsAppUrl))
    {
        <div class="alert alert-success d-flex justify-content-between align-items-center gap-3 mt-3">
            <span>Reserva actualizada. Puede avisar al cliente por WhatsApp.</span>
            <a href="@whatsAppUrl" target="_blank" rel="noopener" class="btn btn-success btn-sm">
                @(TempData["WhatsAppText"] ?? "Enviar WhatsApp")
            </a>
        </div>
    }

    <div class="table-responsive mt-3">
        <table class="table table-hover align-middle app-table">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Codigo</th>
                    <th>Hora</th>
                    <th>Cliente</th>
                    <th>Mesa</th>
                    <th>Personas</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                        <td><span class="reservation-code">@item.CodigoReserva</span></td>
                        <td>@item.Hora.ToString("HH:mm")</td>
                        <td class="fw-semibold">@item.ClienteNombre</td>
                        <td>@item.MesaDescripcion</td>
                        <td>@item.CantidadPersonas</td>
                        <td><span class="status-badge status-@item.Estado.ToLowerInvariant()">@item.Estado</span></td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm" role="group">
                                <a asp-action="Details" asp-route-id="@item.IdReserva" class="btn btn-outline-secondary">Detalle</a>
                                <a asp-action="Edit" asp-route-id="@item.IdReserva" class="btn btn-outline-primary">Editar</a>
                                <a href="@item.WhatsAppUrl" target="_blank" rel="noopener" class="btn btn-outline-success">WhatsApp</a>
                                <a asp-action="Comprobante" asp-route-id="@item.IdReserva" class="btn btn-outline-dark">PDF</a>
                                <button type="button"
                                        class="btn btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#confirmDeleteModal"
                                        data-delete-url="@Url.Action("Delete", "Reservas", new { id = item.IdReserva })"
                                        data-delete-text="Reserva de @item.ClienteNombre el @item.Fecha.ToString("dd/MM/yyyy") a las @item.Hora.ToString("HH:mm")">
                                    Eliminar
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">No se encontraron reservas.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination"
             model="Model"
             view-data='new ViewDataDictionary(ViewData) { ["AriaLabel"] = "Paginacion de reservas", ["RouteValues"] = new { search = ViewBag.Search, estado = ViewBag.Estado, fecha = ViewBag.Fecha, sort = ViewBag.Sort } }' />
</section>

<partial name="_ConfirmDeleteModal" />

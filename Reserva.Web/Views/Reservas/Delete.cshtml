@model ReservaDto

@{
    ViewData["Title"] = "Eliminar reserva";
}

<section class="container page-shell form-card admin-page danger-page">
    <div class="form-heading">
        <span>Accion irreversible</span>
        <strong>Eliminar reserva</strong>
    </div>
    <p class="text-muted">Confirma si deseas eliminar esta reserva.</p>

    <dl class="detail-grid">
        <div><dt>Cliente</dt><dd>@Model.ClienteNombre</dd></div>
        <div><dt>Fecha</dt><dd>@Model.Fecha.ToString("dd/MM/yyyy")</dd></div>
        <div><dt>Hora</dt><dd>@Model.Hora.ToString("HH:mm")</dd></div>
        <div><dt>Estado</dt><dd><span class="status-badge status-@Model.Estado.ToLowerInvariant()">@Model.Estado</span></dd></div>
    </dl>

    <form asp-action="Delete" method="post" class="form-actions mt-4">
        <input type="hidden" asp-for="IdReserva" />
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        <button type="submit" class="btn btn-danger">Eliminar</button>
    </form>
</section>

@model ReservaPublicaViewModel
@{
    ViewData["Title"] = "Reservar";
    var registeredClient = ViewBag.RegisteredClient;
    var hasRegisteredClient = registeredClient is not null;
}

<section class="reservation-public">
    <div class="container reservation-grid">
        <div class="reservation-copy">
            <p class="eyebrow">Reserva publica</p>
            <h1>Prepare su mesa en Mikuy</h1>
            <p>Comparta sus datos, el horario y el tamano del grupo. El sistema buscara la mesa activa mas adecuada.</p>
            <div class="reservation-highlights">
                <span>Horarios segun disponibilidad</span>
                <span>Confirmacion administrativa</span>
                <span>Comentarios para celebraciones</span>
            </div>
        </div>
        <div class="page-shell">
            <div class="form-heading">
                <span>Solicitud</span>
                <strong>Datos de la reserva</strong>
            </div>
            <form asp-action="Reservar" method="post" class="reserva-form reservation-wizard" data-reservation-wizard>
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="wizard-progress" aria-label="Progreso de reserva">
                    <span class="wizard-progress-item active" data-step-indicator="1">1. Reserva</span>
                    <span class="wizard-progress-item" data-step-indicator="2">2. Contacto</span>
                </div>

                <section class="reservation-step active" data-step="1" aria-labelledby="reservationStepOneTitle">
                    <div class="step-heading">
                        <span>Paso 1</span>
                        <h2 id="reservationStepOneTitle">Datos de la reserva</h2>
                        <p>Elija fecha, hora y cantidad de personas para validar disponibilidad antes de compartir sus datos.</p>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <label asp-for="Fecha" class="form-label"></label>
                            <input asp-for="Fecha" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control reserva-fecha" />
                            <span asp-validation-for="Fecha" class="text-danger"></span>
                        </div>
                        <div class="col-12 col-md-4">
                            <label asp-for="Hora" class="form-label"></label>
                            <select asp-for="Hora" asp-items="ViewBag.HorariosDisponibles" class="form-select reserva-hora">
                                <option value="">Seleccione</option>
                            </select>
                            <span asp-validation-for="Hora" class="text-danger"></span>
                        </div>
                        <div class="col-12 col-md-4">
                            <label asp-for="CantidadPersonas" class="form-label"></label>
                            <input asp-for="CantidadPersonas" type="number" min="1" max="24" class="form-control reserva-personas" />
                            <span asp-validation-for="CantidadPersonas" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <div class="availability-panel availability-pending" data-availability-panel aria-live="polite">
                                <span class="availability-icon" data-availability-icon aria-hidden="true">&bull;</span>
                                <div>
                                    <strong data-availability-title>Disponibilidad en tiempo real</strong>
                                    <p data-availability-message>Seleccione fecha, hora y personas para consultar si hay mesa disponible.</p>
                                    <small data-availability-table></small>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 form-actions">
                            <button class="btn btn-accent" type="button" data-next-step disabled>Continuar con mis datos</button>
                        </div>
                    </div>
                </section>

                <section class="reservation-step" data-step="2" aria-labelledby="reservationStepTwoTitle" hidden>
                    <div class="step-heading">
                        <span>Paso 2</span>
                        <h2 id="reservationStepTwoTitle">Datos de contacto</h2>
                        <p>@(hasRegisteredClient ? "Sus datos ya estan registrados. Agregue solo un comentario si desea comunicar algo al equipo." : "Con la mesa disponible, complete sus datos para enviar la solicitud al equipo de Mikuy.")</p>
                    </div>

                    <div class="row g-3">
                        @if (hasRegisteredClient)
                        {
                            <input asp-for="NombreCliente" type="hidden" />
                            <input asp-for="Telefono" type="hidden" />
                            <input asp-for="Correo" type="hidden" />
                            <div class="col-12">
                                <div class="registered-client-summary">
                                    <span>Cliente registrado</span>
                                    <strong>@Model.NombreCliente</strong>
                                    <small>@Model.Telefono - @Model.Correo</small>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="col-12">
                                <label asp-for="NombreCliente" class="form-label"></label>
                                <input asp-for="NombreCliente" class="form-control" />
                                <span asp-validation-for="NombreCliente" class="text-danger"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="Telefono" class="form-label"></label>
                                <input asp-for="Telefono" class="form-control" />
                                <span asp-validation-for="Telefono" class="text-danger"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="Correo" class="form-label"></label>
                                <input asp-for="Correo" class="form-control" />
                                <span asp-validation-for="Correo" class="text-danger"></span>
                            </div>
                        }
                        <div class="col-12">
                            <label asp-for="Comentario" class="form-label"></label>
                            <textarea asp-for="Comentario" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Comentario" class="text-danger"></span>
                        </div>
                        <div class="col-12 form-actions">
                            <button class="btn btn-outline-secondary" type="button" data-prev-step>Volver a disponibilidad</button>
                            <button class="btn btn-accent" type="submit">Solicitar reserva</button>
                        </div>
                    </div>
                </section>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/reservas.js" asp-append-version="true"></script>
}

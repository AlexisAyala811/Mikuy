@model ReservationLookupViewModel

@{
    ViewData["Title"] = "Consultar reserva";
}

<section class="container contact-layout">
    <div>
        <p class="eyebrow">Seguimiento</p>
        <h1>Consultar mi reserva</h1>
        <p>Use su codigo de reserva si lo tiene. Si lo perdio, busque por el correo o telefono usado al reservar.</p>

        <div class="last-reservation-card" data-last-reservation-card hidden>
            <span>Tu ultima reserva</span>
            <strong data-last-reservation-code></strong>
            <small data-last-reservation-meta></small>
            <button type="button" class="btn btn-outline-dark btn-sm" data-use-last-reservation>Ver estado</button>
        </div>

        <form asp-action="Consultar" method="post" class="lookup-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="lookup-form-header">
                <span>Metodo de consulta</span>
                <strong>Busca el estado de tu reserva</strong>
            </div>
            <div class="lookup-method-block">
                <label class="form-label">Consultar por</label>
                <div class="lookup-methods" role="group" aria-label="Metodo de consulta">
                    <input type="radio" class="btn-check" asp-for="MetodoConsulta" value="codigo" id="lookupByCode" checked="@(Model.MetodoConsulta != "contacto")" />
                    <label class="btn btn-outline-dark" for="lookupByCode">Codigo de reserva</label>
                    <input type="radio" class="btn-check" asp-for="MetodoConsulta" value="contacto" id="lookupByContact" checked="@(Model.MetodoConsulta == "contacto")" />
                    <label class="btn btn-outline-dark" for="lookupByContact">Correo/Telefono</label>
                </div>
            </div>
            <div class="lookup-query-row">
                <div class="lookup-field" data-lookup-section="codigo">
                    <label asp-for="CodigoReserva" class="form-label"></label>
                    <input asp-for="CodigoReserva" class="form-control" placeholder="Ej. MIK-20260530-0004" />
                    <span asp-validation-for="CodigoReserva" class="text-danger"></span>
                </div>
                <div class="lookup-field" data-lookup-section="contacto">
                    <label asp-for="Contacto" class="form-label"></label>
                    <input asp-for="Contacto" class="form-control" placeholder="correo@dominio.com o 999999999" />
                    <span asp-validation-for="Contacto" class="text-danger"></span>
                </div>
                <button class="btn btn-accent lookup-submit" type="submit">Consultar estado</button>
            </div>
        </form>
    </div>

    <div class="page-shell">
        @if (Model.Results.Count == 0)
        {
            <div class="empty-state">
                <span>MIK</span>
                <h2 class="h4">Estado de reserva</h2>
                <p class="text-muted mb-0">Aqui vera si su reserva esta pendiente, confirmada o cancelada.</p>
            </div>
        }
        else
        {
            <p class="eyebrow">Resultado</p>
            <div class="lookup-results">
                @foreach (var reserva in Model.Results)
                {
                    <article class="lookup-result-card"
                             data-lookup-result
                             data-code="@reserva.CodigoReserva"
                             data-date="@reserva.Fecha.ToString("dd/MM/yyyy")"
                             data-time="@reserva.Hora.ToString("HH:mm")"
                             data-status="@reserva.Estado">
                        <div class="ticket-header">
                            <span class="reservation-code">@reserva.CodigoReserva</span>
                            <strong class="status-badge status-@reserva.Estado.ToLowerInvariant()">@reserva.Estado</strong>
                        </div>
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Cliente</dt>
                            <dd class="col-sm-8">@reserva.ClienteNombre</dd>
                            <dt class="col-sm-4">Fecha</dt>
                            <dd class="col-sm-8">@reserva.Fecha.ToString("dd/MM/yyyy")</dd>
                            <dt class="col-sm-4">Hora</dt>
                            <dd class="col-sm-8">@reserva.Hora.ToString("HH:mm")</dd>
                            <dt class="col-sm-4">Personas</dt>
                            <dd class="col-sm-8">@reserva.CantidadPersonas</dd>
                            <dt class="col-sm-4">Mesa</dt>
                            <dd class="col-sm-8">@reserva.MesaDescripcion</dd>
                        </dl>
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button type="button" class="btn btn-outline-dark btn-sm" data-copy-text="@reserva.CodigoReserva">Copiar codigo</button>
                            <a asp-action="Comprobante" asp-route-id="@reserva.IdReserva" asp-route-code="@reserva.CodigoReserva" class="btn btn-outline-dark btn-sm">PDF</a>
                            @if (reserva.Estado is "Confirmada" or "Cancelada")
                            {
                                <a href="@reserva.WhatsAppUrl" target="_blank" rel="noopener" class="btn btn-success btn-sm">WhatsApp</a>
                            }
                            @if (reserva.CanCancel)
                            {
                                <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#cancelReservationModal-@reserva.IdReserva">
                                    Cancelar
                                </button>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>

@foreach (var reserva in Model.Results.Where(item => item.CanCancel))
{
    <div class="modal fade" id="cancelReservationModal-@reserva.IdReserva" tabindex="-1" aria-labelledby="cancelReservationModalLabel-@reserva.IdReserva" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="cancelReservationModalLabel-@reserva.IdReserva">Cancelar reserva</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <p>Se cancelara la reserva <strong>@reserva.CodigoReserva</strong> para el @reserva.Fecha.ToString("dd/MM/yyyy") a las @reserva.Hora.ToString("HH:mm").</p>
                    <p class="mb-0 text-muted">El estado cambiara a Cancelada y el equipo de Mikuy vera la actualizacion inmediatamente.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Volver</button>
                    <form asp-action="CancelarConsulta" method="post">
                        <input type="hidden" name="Correo" value="@reserva.ClienteCorreo" />
                        <input type="hidden" name="CodigoReserva" value="@reserva.CodigoReserva" />
                        <input type="hidden" name="ReservaId" value="@reserva.IdReserva" />
                        <button type="submit" class="btn btn-danger">Confirmar cancelacion</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

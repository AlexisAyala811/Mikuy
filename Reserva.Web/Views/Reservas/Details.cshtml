@model ReservaDto

@{
    ViewData["Title"] = "Detalle de reserva";
}

<section class="container page-shell form-card admin-page detail-page">
    <div class="detail-header">
        <div>
            <p class="eyebrow">Detalle operativo</p>
            <h1>Reserva @Model.CodigoReserva</h1>
            <p class="text-muted mb-0">@Model.Hora.ToString("HH:mm") - @Model.ClienteNombre</p>
        </div>
        <div class="detail-actions">
            <a asp-action="Comprobante" asp-route-id="@Model.IdReserva" class="btn btn-outline-dark">PDF</a>
            <a asp-action="Edit" asp-route-id="@Model.IdReserva" class="btn btn-primary">Editar</a>
        </div>
    </div>

    <dl class="detail-grid">
        <div><dt>Codigo</dt><dd><span class="reservation-code">@Model.CodigoReserva</span></dd></div>
        <div><dt>Cliente</dt><dd>@Model.ClienteNombre</dd></div>
        <div><dt>Telefono</dt><dd>@Model.ClienteTelefono</dd></div>
        <div><dt>Fecha</dt><dd>@Model.Fecha.ToString("dd/MM/yyyy")</dd></div>
        <div><dt>Hora</dt><dd>@Model.Hora.ToString("HH:mm")</dd></div>
        <div><dt>Mesa</dt><dd>@Model.MesaDescripcion</dd></div>
        <div><dt>Personas</dt><dd>@Model.CantidadPersonas</dd></div>
        <div><dt>Estado</dt><dd><span class="status-badge status-@Model.Estado.ToLowerInvariant()">@Model.Estado</span></dd></div>
        <div class="detail-wide"><dt>Comentario</dt><dd>@(string.IsNullOrWhiteSpace(Model.Comentario) ? "Sin comentario" : Model.Comentario)</dd></div>
    </dl>

    <div class="form-actions mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>
</section>

@model Reserva.Domain.Entities.Plato
<section class="container page-shell form-card admin-page">
    <div class="form-heading">
        <span>Menu publico</span>
        <strong>@ViewData["Heading"]</strong>
    </div>
    <form asp-action="@ViewData["Action"]" asp-route-id="@Model.IdPlato" method="post" enctype="multipart/form-data" class="row g-3">
        <input asp-for="IdPlato" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="col-md-7">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>
        <div class="col-md-5">
            <label asp-for="Categoria" class="form-label"></label>
            <input asp-for="Categoria" class="form-control" />
            <span asp-validation-for="Categoria" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Descripcion" class="form-label"></label>
            <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Descripcion" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Precio" class="form-label"></label>
            <input asp-for="Precio" class="form-control" />
            <span asp-validation-for="Precio" class="text-danger"></span>
        </div>
        <div class="col-md-8">
            <label asp-for="ImagenUrl" class="form-label"></label>
            <input asp-for="ImagenUrl" class="form-control" readonly />
            <span asp-validation-for="ImagenUrl" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label for="imagenArchivo" class="form-label">Subir imagen</label>
            <input id="imagenArchivo" name="imagenArchivo" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
            <div class="form-text">Se guardara en wwwroot/img/platos.</div>
        </div>
        <div class="col-md-8">
            <div class="dish-image-preview">
                <img src="@Model.ImagenUrl" alt="Vista previa de @Model.Nombre" />
            </div>
        </div>
        <div class="col-12">
            <div class="switch-row">
            <input asp-for="Activo" class="form-check-input" />
            <label asp-for="Activo" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-12 form-actions">
            <a asp-action="Admin" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-accent">Guardar</button>
        </div>
    </form>
</section>

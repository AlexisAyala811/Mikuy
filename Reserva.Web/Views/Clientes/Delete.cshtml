@model ClienteDto

@{
    ViewData["Title"] = "Eliminar cliente";
}

<section class="container page-shell form-card admin-page danger-page">
    <div class="form-heading">
        <span>Accion irreversible</span>
        <strong>Eliminar cliente</strong>
    </div>
    <p class="text-muted">Confirma si deseas eliminar este cliente.</p>

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <dl class="detail-grid">
        <div><dt>Nombre</dt><dd>@Model.Nombre</dd></div>
        <div><dt>Telefono</dt><dd>@Model.Telefono</dd></div>
        <div><dt>Correo</dt><dd>@Model.Correo</dd></div>
    </dl>

    <form asp-action="Delete" method="post" class="form-actions mt-4">
        <input type="hidden" asp-for="IdCliente" />
        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        <button type="submit" class="btn btn-danger">Eliminar</button>
    </form>
</section>

@model ClienteDto

@{
    ViewData["Title"] = "Detalle de cliente";
}

<section class="container page-shell form-card admin-page detail-page">
    <div class="detail-header">
        <div>
            <p class="eyebrow">Detalle del cliente</p>
            <h1>@Model.Nombre</h1>
            <p class="text-muted mb-0">Detalle del cliente</p>
        </div>
        <div class="detail-actions">
            <a asp-action="Edit" asp-route-id="@Model.IdCliente" class="btn btn-primary">Editar</a>
        </div>
    </div>

    <dl class="detail-grid">
        <div><dt>Telefono</dt><dd>@Model.Telefono</dd></div>
        <div><dt>Correo</dt><dd>@Model.Correo</dd></div>
    </dl>

    <div class="form-actions mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>
</section>
